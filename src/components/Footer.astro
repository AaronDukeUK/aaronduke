---
import logoMark from "../assets/images/ad_logo.svg"
import { site } from "../data/site"

const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="footer__container">
    <p class="footer__text">
      <strong>&copy; {year} {site.name}.</strong> {site.footer.text}
    </p>

    <a href="/" aria-label="Home Page" class="logo">
      <img src={logoMark.src ?? logoMark} alt="" class="logo__image" />
    </a>
  </div>
</footer>

<style lang="scss">
  .footer {
    background-color: #011627;
    padding: 2rem;

    @media (max-width: 700px) {
      padding: 2rem 1rem;
    }

    &__container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
      @media (max-width: 700px) {
        flex-direction: column;
        justify-content: center;
        gap: 1rem;
        text-align: center;
      }
    }
    &__text {
      color: #fff;
      font-size: 1rem;
      @media (max-width: 700px) {
        text-align: center;
      }
    }
    strong {
      font-weight: 700;
    }
  }

  .logo__image {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
