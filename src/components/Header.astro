---
import { Icon } from "astro-icon/components"
import logoMark from "../assets/images/ad_logo.svg"
import { site } from "../data/site"
---

<header class="header">
  <div class="header__container">
    <a href="/" aria-label="Home Page" class="logo">
      <img src={logoMark.src ?? logoMark} alt="" class="logo__image" />
    </a>
    <a
      class="header__email"
      href={`mailto:${site.email}`}
      aria-label="Email Me"
    >
      <Icon name="mdi:email" />
    </a>
  </div>
</header>

<style lang="scss">
  .header {
    overflow: hidden;
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 100;
    background-color: #011627;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);
    max-height: 100px;
    transition: all 0.5s ease-in-out;
    padding: 1rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(18px);
    @media (max-width: 700px) {
      padding: 1rem 1rem;
    }

    &__container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
    }
    &__logo {
      width: 3rem;
      height: 3rem;
    }
    &__email {
      color: #011627;
      background-color: #fff;
      border-radius: 50%;
      width: 3rem;
      height: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease-in-out;
      border: 1px solid #011627;
      &:hover {
        color: #fff;
        background-color: #011627;
        border: 1px solid #fff;
      }
    }
  }
  [data-icon] {
    width: 2rem;
    height: 2rem;
  }

  .logo__image {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
