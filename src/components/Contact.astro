---
import { site } from "../data/site"
---

<script>
  const form = document.querySelector('[data-contact-form=""]')
  const formStatus = document.querySelector('[data-form-status=""]')
  const submitButton = form?.querySelector('[type="submit"]')
  const checkbox = document.querySelector('[data-checkbox="inquiry"]')
  const checkboxToggle = document.querySelector(
    '[data-checkbox-toggle="inquiry"]'
  )
  const inquiryDetails = document.querySelector('[data-inquiry-details=""]')

  const phoneInput = document.querySelector('[name="phone"]')
  const projectTypeInput = document.querySelector('[name="project_type"]')

  const budgetSlider = document.querySelector('[data-budget-slider=""]')
  const budgetValue = document.querySelector('[data-budget-value=""]')

  if (form && formStatus) {
    const searchParams = new URLSearchParams(window.location.search)
    const submitted = searchParams.get("submitted") === "contact"

    if (submitted) {
      formStatus.hidden = false
      formStatus.dataset.state = "success"
      formStatus.textContent =
        "Thanks - your message has been sent. I will get back to you soon."
    }

    const fields = form.querySelectorAll(
      'input:not([type="hidden"]):not([type="range"]), textarea'
    )

    fields.forEach((field) => {
      field.addEventListener("invalid", () => {
        field.setAttribute("aria-invalid", "true")
      })

      field.addEventListener("input", () => {
        if (field.validity.valid) {
          field.removeAttribute("aria-invalid")
        }
      })
    })

    const updateStatus = (state, message) => {
      formStatus.hidden = false
      formStatus.dataset.state = state
      formStatus.textContent = message
      formStatus.focus()
    }

    form.addEventListener("submit", async (event) => {
      if (!form.checkValidity()) {
        updateStatus(
          "error",
          "Please complete the required fields and fix any errors before sending."
        )
        return
      }

      event.preventDefault()

      if (submitButton) {
        submitButton.disabled = true
      }

      updateStatus("pending", "Sending your message...")

      try {
        const response = await fetch("/", {
          method: "POST",
          headers: {
            "Content-Type": "application/x-www-form-urlencoded",
          },
          body: new URLSearchParams(new FormData(form)).toString(),
        })

        if (!response.ok) {
          throw new Error("Submission failed")
        }

        form.reset()
        fields.forEach((field) => {
          field.removeAttribute("aria-invalid")
        })

        if (
          checkbox &&
          checkboxToggle &&
          inquiryDetails &&
          phoneInput &&
          projectTypeInput &&
          budgetSlider &&
          budgetValue
        ) {
          checkbox.classList.remove("checked")
          checkboxToggle.setAttribute("aria-expanded", "false")
          inquiryDetails.classList.remove("show")
          inquiryDetails.hidden = true
          phoneInput.tabIndex = -1
          projectTypeInput.tabIndex = -1
          budgetSlider.tabIndex = -1
          budgetSlider.value = "10"
          budgetValue.textContent = budgetSlider.value
        }

        updateStatus(
          "success",
          "Thanks - your message has been sent. I will get back to you soon."
        )
      } catch {
        updateStatus(
          "error",
          "Something went wrong while sending your message. Please try again or email me directly."
        )
      } finally {
        if (submitButton) {
          submitButton.disabled = false
        }
      }
    })
  }

  if (
    checkbox &&
    checkboxToggle &&
    inquiryDetails &&
    phoneInput &&
    projectTypeInput &&
    budgetSlider &&
    budgetValue
  ) {
    const toggleInquiry = () => {
      const isChecked = checkbox.classList.toggle("checked")
      inquiryDetails.classList.toggle("show", isChecked)
      checkboxToggle.setAttribute("aria-expanded", String(isChecked))
      inquiryDetails.hidden = !isChecked
      phoneInput.tabIndex = isChecked ? 0 : -1
      projectTypeInput.tabIndex = isChecked ? 0 : -1
      budgetSlider.tabIndex = isChecked ? 0 : -1
    }

    checkboxToggle.addEventListener("click", toggleInquiry)

    checkboxToggle.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault()
        toggleInquiry()
      }
    })

    inquiryDetails.hidden = true
    checkboxToggle.setAttribute("aria-expanded", "false")
    budgetValue.textContent = budgetSlider.value

    budgetSlider.addEventListener("input", () => {
      budgetValue.textContent = budgetSlider.value
    })
  }
</script>

<section class="contact" id="contact">
  <div class="contact__container">
    <div class="contact__header">
      <h2 class="hidden hidden__left">{site.contact.heading}</h2>
      <a
        class="btn hidden hidden__right"
        href={`mailto:${site.email}`}
        aria-label={site.contact.ctaLabel}>{site.contact.ctaLabel}</a
      >
    </div>

    <form
      action="/?submitted=contact#contact"
      method="POST"
      class="form"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      data-contact-form=""
      name={site.contact.formName}
    >
      <input type="hidden" name="form-name" value={site.contact.formName} />
      <p class="sr-only">
        <label for="contact-bot-field">Do not fill in this field</label>
        <input id="contact-bot-field" name="bot-field" />
      </p>
      <p
        class="form__status"
        data-form-status=""
        aria-live="polite"
        tabindex="-1"
        hidden
      ></p>
      <label class="sr-only" for="contact-name">Name</label>
      <input
        id="contact-name"
        type="text"
        placeholder="NAME"
        autocomplete="name"
        name="name"
        minlength="2"
        maxlength="100"
        required
      />

      <label class="sr-only" for="contact-email">Email address</label>
      <input
        id="contact-email"
        type="email"
        placeholder="EMAIL ADDRESS"
        name="email"
        autocomplete="email"
        maxlength="120"
        required
      />

      <!-- Checkbox -->
      <button
        type="button"
        class="form__inquiry"
        data-checkbox-toggle="inquiry"
        aria-controls="inquiry-details"
        aria-expanded="false"
      >
        <span class="form__checkbox" data-checkbox="inquiry" data-checked="true"
        ></span>
        <span>Inquiry</span>
      </button>

      <!-- Dropdown -->
      <div
        class="form__inquiry-details"
        id="inquiry-details"
        data-inquiry-details=""
        hidden
      >
        <div class="form__inquiry-wrapper">
          <div class="form__budget">
            <label class="sr-only" for="budget-slider">Budget</label>
            <p>Budget</p>
            <div>
              <input
                id="budget-slider"
                tabindex="-1"
                type="range"
                name="budget_slider"
                min="1"
                max="20"
                step="1"
                value="10"
                data-budget-slider=""
              />

              <p>£ <span data-budget-value="">10</span>K</p>
            </div>
          </div>

          <label class="sr-only" for="project-type">Project type</label>
          <input
            id="project-type"
            tabindex="-1"
            type="text"
            name="project_type"
            placeholder="PROJECT TYPE (E.G. WEBSITE, MOBILE APP)"
          />

          <label class="sr-only" for="phone-number">Phone number</label>
          <input
            id="phone-number"
            tabindex="-1"
            type="tel"
            name="phone"
            autocomplete="tel"
            placeholder="PHONE NUMBER"
          />
        </div>
      </div>

      <label class="sr-only" for="contact-message">Message</label>
      <textarea
        id="contact-message"
        name="message"
        placeholder="MESSAGE"
        rows="6"
        minlength="10"
        maxlength="2000"
        required></textarea>

      <button
        aria-label="Submit Form"
        type="submit"
        class="form__submit">Send</button
      >
    </form>
  </div>
</section>

<style lang="scss">
  .contact {
    padding: 4rem 2rem;
    overflow: hidden;
    @media (max-width: 700px) {
      padding: 4rem 1rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
    }

    &__header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      @media (max-width: 700px) {
        flex-direction: column;
        justify-content: center;
        gap: 1rem;
        text-align: center;
      }
    }
  }
  .form {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    border-radius: 0.25rem;
    @media (max-width: 700px) {
      align-items: center;
      text-align: center;
    }

    &__status {
      width: 100%;
      margin-bottom: 0.75rem;
      padding: 0.85rem 1rem;
      border-radius: 0.25rem;
      font-size: 0.95rem;
      line-height: 1.5;
      color: #011627;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(1, 22, 39, 0.14);
    }

    &__status[data-state="success"] {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      background: #f4fbf7;
      border-color: #1d6b43;
      color: #154b30;
    }

    &__status[data-state="success"]::before {
      content: "✓";
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      width: 1.4rem;
      height: 1.4rem;
      margin-top: 0.05rem;
      border-radius: 999px;
      background: #1d6b43;
      color: #fff;
      font-size: 0.9rem;
      font-weight: 700;
      line-height: 1;
    }

    &__status[data-state="error"] {
      background: #fff;
      border-color: #8b1e3f;
      color: #5f1028;
    }

    &__status[data-state="pending"] {
      background: rgba(255, 255, 255, 0.92);
      border-color: rgba(1, 22, 39, 0.22);
    }

    input,
    textarea {
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      letter-spacing: 1px;
      margin-bottom: 0.5rem;
      width: 100%;
      color: #011627;
      resize: none;
      border: 1px solid #011627;
      border-radius: 0.25rem;
      transition:
        background-color 0.2s ease,
        color 0.2s ease,
        border-color 0.2s ease;
      &:focus {
        outline: none;
        background-color: #011627;
        color: #fff;
        &::placeholder {
          color: #fff;
        }
      }

      &::placeholder {
        color: #011627;
      }

      &[aria-invalid="true"] {
        border-color: #8b1e3f;
      }
    }

    input[type="range"] {
      -webkit-appearance: none;
      width: 100%;
      flex-grow: 1;
      height: 2px;
      background: #d3d3d3;
      padding: 0;
      margin-bottom: 1rem;
      &:focus {
        background: #011627;
      }

      &::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 20px;
        height: 20px;
        background: #011627;
        border-radius: 50%;
        cursor: pointer;
      }
    }

    &__inquiry {
      width: 100%;
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
      background-color: #fff;
      border: 1px solid #011627;
      border-radius: 0.25rem;
      cursor: pointer;
      span {
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
        color: #011627;
      }
    }

    &__checkbox {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 1.25rem;
      height: 1.25rem;
      cursor: pointer;
      transition: all 0.2s ease-in-out;
      border: 1px solid #011627;
      border-radius: 0.25rem;
      &.checked {
        &::after {
          content: "";
          display: block;
          width: 0.5rem;
          height: 0.5rem;
          background-color: #011627;
          border-radius: 0.25rem;
        }
      }
    }

    &__inquiry-details {
      width: 100%;
      max-height: 0px;
      overflow: hidden;
      transition:
        max-height 0.4s ease-in-out,
        opacity 0.4s ease-in-out;
      opacity: 0;

      &.show {
        max-height: 28rem;
        opacity: 1;
      }
    }

    &__inquiry-wrapper {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: flex-start;
    }

    &__budget {
      width: 100%;
      display: flex;
      padding: 0.75rem 1rem;
      margin-bottom: 0.5rem;
      background-color: #fff;
      border: 1px solid #011627;
      border-radius: 0.25rem;
      @media (max-width: 700px) {
        flex-direction: column;
        align-items: flex-start;
        text-align: left;
        gap: 0.75rem;
      }
      div {
        width: 100%;
      }
      p {
        font-size: 0.85rem;
        letter-spacing: 1px;
        color: #011627;
        text-transform: uppercase;
        margin-right: 2rem;
        @media (max-width: 700px) {
          margin-right: 0;
        }
      }
      span {
        color: #011627;
      }
    }
    &__submit {
      width: 10rem;
      display: inline-block;
      text-transform: uppercase;
      text-decoration: none;
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: 2px;
      color: #fff;
      background: #011627;
      padding: 1rem 2rem;
      border-radius: 0.25rem;
      transition: all 0.3s ease-in-out;
      border: 1px solid #011627;
      cursor: pointer;
      &:disabled {
        cursor: wait;
        opacity: 0.8;
      }
      &:hover {
        background: #fff;
        color: #011627;
        border: 1px solid #011627;
      }
      @media (max-width: 700px) {
        align-self: center;
      }
    }
  }
</style>
